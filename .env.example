##########################################################
Example environment variable configurations for the Letta
client skill. Uncomment and configure the sections you need.
##########################################################

##########################################################
                Letta Server Connection
##########################################################
# Required for connecting to a Letta server (self-hosted or cloud)
LETTA_BASE_URL=http://localhost:8283
LETTA_API_KEY=${LETTA_API_KEY}

##########################################################
                Default Model Configuration
##########################################################
# Default model to use when creating agents (format depends on provider)
# For OpenRouter: OpenRouter/provider/model:free
# For OpenAI: openai/gpt-4
# For Anthropic: anthropic/claude-3-opus
LETTA_MODEL=OpenRouter/z-ai/glm-4.5-air:free

##########################################################
                OpenRouter configuration
##########################################################
# OPENROUTER_API_KEY=your_openrouter_key_here

##########################################################
                OpenAI configuration
##########################################################
# OPENAI_API_KEY=your_openai_key_here

##########################################################
                Anthropic configuration
##########################################################
# ANTHROPIC_API_KEY=your_anthropic_key_here

##########################################################
                Ollama configuration
##########################################################
# OLLAMA_BASE_URL="http://host.docker.internal:11434"

##########################################################
                vLLM configuration
##########################################################
# VLLM_API_BASE="http://host.docker.internal:8000"

##########################################################
                PostgreSQL configuration (self-hosted)
##########################################################
# Connection string format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
LETTA_POSTGRES_URI=postgresql://${POSTGRES_USER:-letta}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB:-letta}

# Alternative: Individual PostgreSQL variables
# POSTGRES_USER=letta
# POSTGRES_PASSWORD=your_postgres_password_here
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=letta

##########################################################
                Docker configuration
##########################################################
# Docker networking for PostgreSQL access from containers
# POSTGRES_DOCKER_HOST=host.docker.internal

# Letta server container name (for health checks)
# LETTA_CONTAINER_NAME=letta-server
